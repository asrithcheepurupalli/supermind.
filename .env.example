# OAuth Configuration
# Get these from your OAuth provider's developer console

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# GitHub OAuth
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Apple OAuth
VITE_APPLE_CLIENT_ID=your_apple_client_id_here
VITE_APPLE_CLIENT_SECRET=your_apple_client_secret_here

# App Configuration
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# Security
VITE_ENCRYPTION_KEY=your_encryption_key_here